<div id="three-portal-container" class="absolute inset-0 w-full h-full pointer-events-none opacity-0 transition-opacity duration-1000"></div>

<script>
    import * as THREE from 'three';

    const container = document.getElementById('three-portal-container');
    if (container) {
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 5;

        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        container.appendChild(renderer.domElement);

        // --- THE DIMENSIONAL TUNNEL ---
        const tunnelSegments = 100;
        const tunnelRadius = 2;
        const tunnelPoints: THREE.Vector3[] = [];

        for (let i = 0; i <= tunnelSegments; i++) {
            tunnelPoints.push(new THREE.Vector3(0, 0, -i * 2));
        }

        const curve = new THREE.CatmullRomCurve3(tunnelPoints);
        const tunnelGeo = new THREE.TubeGeometry(curve, tunnelSegments, tunnelRadius, 8, false);

        const tunnelMat = new THREE.MeshBasicMaterial({
            color: 0xf8d44e,
            wireframe: true,
            transparent: true,
            opacity: 0.2,
            blending: THREE.AdditiveBlending
        });

        const tunnel = new THREE.Mesh(tunnelGeo, tunnelMat);
        scene.add(tunnel);

        // --- DATA PARTICLES ---
        const particleCount = 1000;
        const partGeo = new THREE.BufferGeometry();
        const partPos = new Float32Array(particleCount * 3);

        for (let i = 0; i < particleCount; i++) {
            const angle = Math.random() * Math.PI * 2;
            const radius = 1 + Math.random() * 2;
            partPos[i * 3] = Math.cos(angle) * radius;
            partPos[i * 3 + 1] = Math.sin(angle) * radius;
            partPos[i * 3 + 2] = -Math.random() * 200;
        }

        partGeo.setAttribute('position', new THREE.BufferAttribute(partPos, 3));
        const partMat = new THREE.PointsMaterial({
            color: 0xf8d44e,
            size: 0.05,
            transparent: true,
            opacity: 0.6,
            blending: THREE.AdditiveBlending
        });
        const particles = new THREE.Points(partGeo, partMat);
        scene.add(particles);

        // --- SCROLL INTERACTION ---
        let scrollY = 0;
        window.addEventListener('scroll', () => {
            const portalSection = document.getElementById('portal-section');
            if (portalSection) {
                const rect = portalSection.getBoundingClientRect();
                const progress = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));

                // Show container as we enter the transition
                container.style.opacity = (progress > 0.1 && progress < 0.98) ? '1' : '0';

                // Move camera through the tunnel
                camera.position.z = 5 - (progress * 100);

                // Rotate tunnel
                tunnel.rotation.z = progress * Math.PI * 2;

                // Fade out as we reach the game
                partMat.opacity = Math.max(0, 0.6 - (progress - 0.8) * 6);
                tunnelMat.opacity = Math.max(0, 0.2 - (progress - 0.8) * 2);
            }
        });

        function animate() {
            requestAnimationFrame(animate);

            // Subtle pulse
            const t = Date.now() * 0.001;
            tunnelMat.opacity = 0.1 + Math.sin(t * 2) * 0.05;

            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    }
</script>
